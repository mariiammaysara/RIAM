# ==============================================================================
# Riam Backend — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ==============================================================================

# ── General ───────────────────────────────────────────────────────────────────
ENV=development
# ENV=production   ← uncomment for production
PROJECT_NAME="Riam Support Builder API"

# ── Database ──────────────────────────────────────────────────────────────────
# Local Docker (default): postgresql://postgres:postgres@localhost:5432/riam
# Neon Postgres:          postgresql://user:pass@ep-xxx.neon.tech/neondb?ssl=true
# Note: asyncpg driver and ssl param are handled automatically by config.py
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/riam
TEST_DATABASE_URL=sqlite+aiosqlite:///:memory:

# ── Clerk Authentication ───────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY=sk_test_REPLACE_ME
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# ── LLM & Embeddings ──────────────────────────────────────────────────────────
# Providers: gemini | openai | anthropic | groq
# Default (free, zero-cost): groq + huggingface
LLM_PROVIDER=groq
EMBEDDING_PROVIDER=huggingface

# Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=REPLACE_ME

# OpenAI (only needed if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-proj-REPLACE_ME
OPENAI_MODEL=gpt-4o

# Anthropic (only needed if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Groq — free tier: https://console.groq.com/keys
GROQ_API_KEY=gsk_REPLACE_ME

# ── Observability / LangSmith ─────────────────────────────────────────────────
# Get your key at https://smith.langchain.com → Settings → API Keys
# Set to false to disable tracing entirely
LANGCHAIN_TRACING_V2=false
LANGSMITH_API_KEY=lsv2_pt_REPLACE_ME
LANGSMITH_PROJECT=riam-support-agent

# ── Web Crawler (Firecrawl) ────────────────────────────────────────────────────
# Get your key at https://www.firecrawl.dev → Dashboard → API Keys
# Leave empty to fall back to basic URL loader
FIRECRAWL_API_KEY=fc-REPLACE_ME

# ── CORS / Frontend ───────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Local dev:  http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_API_URL=http://localhost:8000
BACKEND_CORS_ORIGINS=http://localhost:3000
